int main() {
    printf("reading file\n");
    char *buf = read_file(MINECRAFT_PATH"/versions/26.1/26.1.json");
    printf("parsing json\n");
    cJSON *json = cJSON_Parse(buf);
    if (!json) {
        printf("SOMETHING HORRIBLE HAPPENED");
        return 1;
    }
    puts("running extract_wrapper");
    extract_wrapper(json);
    return 0;
